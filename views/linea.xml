<odoo>
  <data>
    <record model="ir.ui.view" id="linea_form_view">
      <field name="name">linea.form</field>
      <field name="model">odoo_basico.linea</field>
      <field name="arch" type="xml">
        <form string="Formulario Línea factura">
          <header>
          </header>
          <sheet>
            <group>
              <field name="descripcion_da_liña"/>
              <field name="name_da_factura"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>


    <record model="ir.ui.view" id="linea_tree_view">
      <field name="name">linea.tree</field>
      <field name="model">odoo_basico.linea</field>
      <field name="arch" type="xml">
        <tree string="informacion Tree">
          <field name="descripcion_da_liña"/>
        </tree>
      </field>
    </record>

    <record model="ir.actions.act_window" id="linea_list_action">
      <field name="name">Línea factura</field><!--O que se visualiza na parte superior esquerda-->
      <field name="res_model">odoo_basico.linea</field>
      <field name="view_type">form</field>
      <field name="view_mode">tree,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">Tes que crear o primeiro rexistro</p>
      </field>
    </record>

  </data>
</odoo>