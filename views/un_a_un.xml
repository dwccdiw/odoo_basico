<odoo>
  <data>
    <record model="ir.ui.view" id="un_a_un_form_view">
      <field name="name">un_a_un.form</field>
      <field name="model">odoo_basico.un_a_un</field>
      <field name="arch" type="xml">
        <form string="Formulario un_a_un">
          <header>
          </header>
          <sheet>
            <group>
              <field name="name"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>


    <record model="ir.ui.view" id="un_a_un_tree_view">
      <field name="name">un_a_un.tree</field>
      <field name="model">odoo_basico.un_a_un</field>
      <field name="arch" type="xml">
        <tree string="informacion Tree">
          <field name="name"/>
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="un_a_un_search_view">
      <field name="name">un_a_un.search</field>
      <field name="model">odoo_basico.un_a_un</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
        </search>
      </field>
    </record>

    <record model="ir.actions.act_window" id="un_a_un_list_action">
      <field name="name">A acción de un_a_un</field><!--O que se visualiza na parte superior esquerda-->
      <field name="res_model">odoo_basico.un_a_un</field>
      <field name="view_type">form</field>
      <field name="view_mode">tree,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">Tes que crear o primeiro rexistro</p>
      </field>
    </record>

  </data>
</odoo>